# ============================================================================
# LLM Backend Configuration
# ============================================================================
# Backend selector: "ollama" (local), "openai", "openrouter", or "gemini"
BACKEND=ollama

# Model identifier (meaning depends on backend)
MODEL=eurecom-ds/phi-3-mini-4k-socratic

# Generation temperature (0.0-1.0, default: 0.3)
TEMPERATURE=0.3

# ── Ollama (local development) ──────────────────────────────────────────────
# Ollama server address
OLLAMA_HOST=http://localhost:11434

# ── OpenAI ──────────────────────────────────────────────────────────────────
# OpenAI API key (get from https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-proj-...

# ── OpenRouter ──────────────────────────────────────────────────────────────
# OpenRouter API key (get from https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-v1-...
# OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Google Gemini ───────────────────────────────────────────────────────────
# Gemini API key (get from https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIzaSy...

# ============================================================================
# Developer Mode
# ============================================================================
# Enable dev-mode sidebar controls (true/false)
DEV_MODE=false

# ============================================================================
# Qualtrics Integration
# ============================================================================
# Post-session survey URL (with placeholders for pid and condition)
QUALTRICS_POST_SURVEY_URL=https://fra1.qualtrics.com/jfe/form/SV_37uMu9WF3PngHFI?pid={pid}&wave=post&condition={condition}

# Debriefing URL for withdrawn participants
QUALTRICS_DEBRIEFING_URL=https://your-institution.qualtrics.com/jfe/form/YOUR_DEBRIEF_ID?pid={pid}
