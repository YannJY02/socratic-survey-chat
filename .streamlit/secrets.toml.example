# ============================================================================
# Streamlit Cloud Secrets Configuration
# ============================================================================
# Copy this file's contents to your Streamlit Cloud app's Secrets settings:
# https://share.streamlit.io → Your App → Settings → Secrets
#
# DO NOT commit secrets.toml to GitHub (it's already in .gitignore)
# ============================================================================

# ── LLM Backend Configuration ───────────────────────────────────────────────
# Backend selector: "ollama", "openai", "openrouter", or "gemini"
BACKEND = "openrouter"

# Model identifier (meaning depends on backend)
MODEL = "google/gemini-2.5-flash"

# Generation temperature (0.0-1.0)
TEMPERATURE = "0.3"

# ── API Keys (uncomment the one you need) ───────────────────────────────────
# OpenAI API key
# OPENAI_API_KEY = "sk-proj-..."

# OpenRouter API key (supports 200+ models including free tiers)
OPENROUTER_API_KEY = "sk-or-v1-..."

# Google Gemini API key
# GEMINI_API_KEY = "AIzaSy..."

# ── Qualtrics Integration ───────────────────────────────────────────────────
QUALTRICS_POST_SURVEY_URL = "https://fra1.qualtrics.com/jfe/form/SV_37uMu9WF3PngHFI?pid={pid}&wave=post&condition={condition}"
QUALTRICS_DEBRIEFING_URL = "https://your-institution.qualtrics.com/jfe/form/YOUR_DEBRIEF_ID?pid={pid}"

# ── Developer Mode ──────────────────────────────────────────────────────────
# Enable dev-mode sidebar controls (set to "false" for production)
DEV_MODE = "false"
